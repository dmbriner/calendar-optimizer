# Notion Integration Token
# Get from: https://www.notion.so/my-integrations → New integration → copy "Internal Integration Token"
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API Key (free tier)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Calendar OAuth credentials file path (downloaded from Google Cloud Console)
# See SETUP.md for instructions
GOOGLE_CREDENTIALS_PATH=credentials.json

# Scheduling preferences
WORK_DAY_START=8        # earliest hour to schedule work (24h)
WORK_DAY_END=22         # latest hour to schedule work (24h)
MAX_HOURS_PER_DAY=4     # max study hours to schedule per day
LOOK_AHEAD_DAYS=14      # how many days ahead to plan
TIMEZONE=America/New_York
